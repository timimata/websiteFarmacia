# ──────────────────────────────────────────────────────────────
# npm configuration — supply-chain security hardening
# ──────────────────────────────────────────────────────────────

# Always generate / verify package-lock.json to ensure reproducible installs
package-lock=true

# Ignore lifecycle scripts from dependencies (prevents malicious postinstall)
ignore-scripts=true

# Use exact versions to avoid surprise updates
save-exact=true

# Audit packages automatically on install
audit=true

# Require npm >= 9 (stricter peer deps handling)
engine-strict=true
