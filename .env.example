# ──────────────────────────────────────────────────────────────
# Environment Variables — Farmácia Ascensão Nunes
# ──────────────────────────────────────────────────────────────
#
# Copy this file to .env (or .env.production) and fill in values.
#
# SECURITY NOTE (OWASP):
#   • Only VITE_* variables are exposed to the client bundle.
#   • NEVER prefix secrets (API keys, tokens, passwords) with VITE_.
#   • Keep secrets in server-side env vars or a secrets manager.
# ──────────────────────────────────────────────────────────────

# Public site URL (used for canonical links, OG tags, sitemap).
# This is NOT a secret — it is the publicly visible domain (sem barra final).
VITE_SITE_URL=https://www.farmaciaascensaonunes.com
